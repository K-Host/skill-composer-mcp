# .env 示例文件
# 复制为 .env 并修改相应配置

# 技能搜索路径（冒号或分号分隔）
SKILLS_PATHS=~/.claude/skills:~/.cursor/skills:./.skills

# LLM 配置
SKILL_COMPOSER_LLM_PROVIDER=ollama
# SKILL_COMPOSER_LLM_API_KEY=your-api-key
SKILL_COMPOSER_LLM_MODEL=qwen2.5:7b
# SKILL_COMPOSER_LLM_BASE_URL=http://localhost:11434

# 输出配置
SKILL_COMPOSER_OUTPUT_DEFAULT_MODE=diff

# 解析器配置
SKILL_COMPOSER_PARSER_FALLBACK_TO_LLM=false

# 组合技能保存目录
# SKILL_COMPOSER_COMPOSED_SKILLS_DIR=~/.composed_skills
